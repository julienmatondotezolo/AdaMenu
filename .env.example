# AdaMenu Frontend - Environment Configuration Template
# Copy this file to .env.local and configure for your environment

# AI Import API URL - Backend API for AI-powered menu import
NEXT_PUBLIC_AI_API_URL=https://ada.mindgen.app

# Menu API URL - for reading menu data  
NEXT_PUBLIC_MENU_API_URL=https://ada.mindgen.app/api/v1/menu

# Development URLs (for local development)
# NEXT_PUBLIC_AI_API_URL=http://localhost:3002
# NEXT_PUBLIC_MENU_API_URL=http://localhost:3002/api/v1/menu